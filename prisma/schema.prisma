datasource db {
  provider = "sqlite"
}

generator client {
  provider = "prisma-client-js"
}

model Product {
  id              String   @id @default(uuid())
  code            String
  description     String
  quantity        Float    
  unitMeasurement String
  unitPrice       Float
  totalPrice      Float
  userId          String?  // <-- PREPARADO PARA O AUTH: Identifica o dono do estoque
  createdAt       DateTime @default(now())

  @@map("products")
}