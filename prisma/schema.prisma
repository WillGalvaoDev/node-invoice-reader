datasource db {
  provider = "postgresql"
}

generator client {
  provider   = "prisma-client-js"
  engineType = "binary"
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  name      String
  password  String
  createdAt DateTime @default(now())

  // Relacionamentos
  ownedCompanies  Company[]             @relation("CompanyOwner")
  collaborations  CompanyCollaborator[]
  auditLogs       AuditLog[]
  createdProducts Product[]             @relation("CreatedBy")

  @@map("users")
}

model Company {
  id        String   @id @default(uuid())
  name      String
  cnpj      String   @unique // 👈 Obrigatório e único
  ownerId   String
  createdAt DateTime @default(now())

  // Relacionamentos
  owner        User                  @relation("CompanyOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  stocks       Stock[]
  collaborators CompanyCollaborator[]
  auditLogs    AuditLog[]

  @@map("companies")
}

model CompanyCollaborator {
  id        String   @id @default(uuid())
  companyId String
  userId    String
  createdAt DateTime @default(now())

  // Relacionamentos
  company     Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user        User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  permissions StockPermission[]

  @@unique([companyId, userId])
  @@map("company_collaborators")
}

model Stock {
  id        String   @id @default(uuid())
  name      String
  companyId String
  createdAt DateTime @default(now())

  // Relacionamentos
  company     Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)
  products    Product[]
  permissions StockPermission[]
  auditLogs   AuditLog[]

  @@unique([companyId, name])
  @@map("stocks")
}

model StockPermission {
  id             String  @id @default(uuid())
  collaboratorId String
  stockId        String
  canView        Boolean @default(false)
  canCreate      Boolean @default(false)
  canEdit        Boolean @default(false)
  canDelete      Boolean @default(false)

  // Relacionamentos
  collaborator CompanyCollaborator @relation(fields: [collaboratorId], references: [id], onDelete: Cascade)
  stock        Stock               @relation(fields: [stockId], references: [id], onDelete: Cascade)

  @@unique([collaboratorId, stockId])
  @@map("stock_permissions")
}

model Product {
  id              String   @id @default(uuid())
  code            String
  ean             String?  // Opcional por enquanto
  ncm             String?  // Opcional por enquanto
  description     String
  quantity        Decimal  @db.Decimal(12, 4)
  unitMeasurement String
  unitPrice       Decimal  @db.Decimal(12, 2)
  totalPrice      Decimal  @db.Decimal(12, 2)
  createdAt       DateTime @default(now())

  // Relacionamento com Estoque
  stockId String
  stock   Stock  @relation(fields: [stockId], references: [id], onDelete: Cascade)

  // Rastreabilidade de quem cadastrou
  userId String?
  user   User?   @relation("CreatedBy", fields: [userId], references: [id], onDelete: SetNull)

  @@unique([stockId, code])
  @@index([stockId])
  @@map("products")
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  READ_INVOICE
}

model AuditLog {
  id          String      @id @default(uuid())
  companyId   String?
  stockId     String?
  userId      String?
  action      AuditAction
  details     String?
  entity      String
  entityId    String?
  description String?
  previousState Json?
  newState      Json?
  createdAt   DateTime    @default(now())

  // Relacionamentos
  company Company? @relation(fields: [companyId], references: [id], onDelete: SetNull)
  stock   Stock?   @relation(fields: [stockId], references: [id], onDelete: SetNull)
  user    User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@map("audit_logs")
}